      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "allowed_pattern": "",
            "arn": "arn:aws:ssm:ap-northeast-2:284484063229:parameter/supplement-rec/dev/adot-config",
            "data_type": "text",
