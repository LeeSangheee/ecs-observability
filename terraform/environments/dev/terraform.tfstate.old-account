              "Environment": "dev",
              "ManagedBy": "terraform",
              "Project": "supplement-rec",
              "Repository": "ecs-observability"
            },
            "workspace_id": "ws-575a1e7d-fc5e-4783-b009-7b680150cedd"
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "private": "bnVsbA==",
          "dependencies": [
